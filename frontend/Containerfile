# Stage 1: Build
FROM docker.io/oven/bun:1.3.10 as builder
WORKDIR /app

# Sebaiknya COPY lockfile juga jika sudah ada di laptop agar versi package konsisten
COPY package.json bun.lockb* ./ 

# Jika di laptop belum ada lockfile, bun install akan tetap jalan
RUN bun install

# Copy sisanya
COPY . .

# Build Nuxt (outputnya ada di folder .output)
RUN bun run build

# Stage 2: Runtime
FROM docker.io/oven/bun:1.3.10-slim AS runtime
WORKDIR /app

# 1. Salin hasil build (Ini yang paling penting)
COPY --from=builder /app/.output ./.output

# 2. Salin package.json
COPY --from=builder /app/package.json ./package.json

# 3. Salin lockfile secara spesifik (Gunakan nama file yang ada di folder frontend kamu)
# Jika filenya bun.lockb, tulis bun.lockb. Jika bun.lock, tulis bun.lock.
COPY --from=builder /app/bun.lock* ./bun.lock*

# 4. Install production dependencies
RUN bun install --production

ENV PORT=3000
ENV HOST=0.0.0.0

EXPOSE 3000
CMD ["bun", "run", "dev", "--host", "0.0.0.0"]